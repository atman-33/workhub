{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "workhub",
  "identifier": "com.atman33.workhub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "workhub — All-in-one Dev Hub",
        "dragDropEnabled": false,
        "width": 1020,
        "height": 700,
        "minWidth": 720,
        "minHeight": 440
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.ico"]
  }
}
